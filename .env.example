# =============================================================================
# TestFramework2 — environment configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Site under test
# The base URL of the e-commerce site you are testing.
# -----------------------------------------------------------------------------
BASE_URL=https://practicesoftwaretesting.com/

# -----------------------------------------------------------------------------
# Browser settings
# BROWSER: chromium | firefox | webkit
# -----------------------------------------------------------------------------
HEADLESS_MODE=true
BROWSER=chromium

# -----------------------------------------------------------------------------
# Search / data-driven settings
# USE_CSV_DATA: true  = load search terms from data/search_terms.csv
#              false = use SINGLE_SEARCH_TERM below
# SINGLE_SEARCH_TERM: term used when USE_CSV_DATA=false
# PDP_TEST_TERMS: comma-separated terms used by test_pdp.py
# -----------------------------------------------------------------------------
USE_CSV_DATA=true
SINGLE_SEARCH_TERM=chisel
PDP_TEST_TERMS=chisel,hammer,shirt

# -----------------------------------------------------------------------------
# Timeouts
# DEFAULT_TIMEOUT: Playwright element wait timeout in milliseconds
# -----------------------------------------------------------------------------
DEFAULT_TIMEOUT=10000

# -----------------------------------------------------------------------------
# Jira integration — automatic bug reporting on test failure
#
# How to get these values:
#
# JIRA_URL
#   Your Atlassian site URL.
#   Find it by logging into Jira and copying the base URL from your browser.
#   Format: https://<your-domain>.atlassian.net
#   → https://id.atlassian.com/login
#
# JIRA_EMAIL
#   The email address of the Atlassian account that will create the issues.
#   This must be the account the API token below belongs to.
#
# JIRA_API_TOKEN
#   A personal API token for the account above.
#   Generate one here (you must be logged in):
#   → https://id.atlassian.com/manage-profile/security/api-tokens
#   Click "Create API token", give it a label, copy the value immediately
#   (it is only shown once).
#
# JIRA_PROJECT_KEY
#   The short key of the Jira project where bugs should be created.
#   Find it in Jira: open your project → the key appears in the URL and
#   next to every issue number (e.g. "PROJ" in issue PROJ-123).
#   → https://<your-domain>.atlassian.net/jira/projects
# -----------------------------------------------------------------------------
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@your-provider.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=your-project-key
